# =========================================================================
# Variables de entorno — Washington 2346 Showroom
#
# TODOS los valores de este archivo son placeholders funcionales para
# desarrollo local. `npm install` copia este archivo a `.env` si no existe,
# así el proyecto arranca sin crear ninguna cuenta externa.
#
# Antes de ir a producción, reemplazar cada valor marcado con
# "# placeholder — reemplazar en producción".
# =========================================================================

# Base de datos.
# Desarrollo: SQLite local (no requiere cuenta).
# Producción: cambiar a la connection string de Postgres/Supabase y cambiar
# el `provider` en prisma/schema.prisma de "sqlite" a "postgresql".
DATABASE_URL="file:./dev.db" # placeholder — reemplazar en producción

# NextAuth
NEXTAUTH_SECRET="dev-secret-washington-2346-cambiar-en-produccion" # placeholder — reemplazar en producción
NEXTAUTH_URL=http://localhost:3000

# Resend (emails de nuevos leads). Con el placeholder, los emails se loguean
# en consola como [EMAIL MOCK] en vez de enviarse.
RESEND_API_KEY="placeholder" # placeholder — reemplazar en producción
RESEND_FROM_EMAIL="showroom@washington2346.local" # placeholder — reemplazar en producción

# Cloudflare R2 (storage de renders/planos/videos). Con placeholders, el
# helper lib/storage.ts genera URLs de picsum.photos en vez de subir.
R2_ACCESS_KEY_ID="placeholder" # placeholder — reemplazar en producción
R2_SECRET_ACCESS_KEY="placeholder" # placeholder — reemplazar en producción
R2_ENDPOINT="placeholder" # placeholder — reemplazar en producción
R2_BUCKET_NAME="placeholder" # placeholder — reemplazar en producción
R2_PUBLIC_URL="placeholder" # placeholder — reemplazar en producción

# Google Maps (página /ubicacion). Con el placeholder se muestra un mapa
# estático de fallback sin romper la página.
# NEXT_PUBLIC_ porque el mapa se renderiza en el cliente.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="placeholder" # placeholder — reemplazar en producción

# WhatsApp del desarrollador (botón de contacto directo).
NEXT_PUBLIC_WHATSAPP_NUMBER="5491100000000" # placeholder — reemplazar en producción
